// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Seed ───────────────────────────────────────────────────────────────────

// npx prisma db seed -> ts-node prisma/seed.ts

model Exercise {
  /// Short stable ID matching the frontend (e.g. 'wm1', 't4')
  id          String   @id
  name        String
  description String
  category    String
  wallTypes   String[]
  levels      String[]
  durationMin Int
  durationMax Int
  /// 1-10 intensity scale
  intensity   Int
  equipment   String[]
  injuryRisk  String[]
  focus       String[]
}

model User {
  id        String   @id @default(cuid())
  googleId  String   @unique
  email     String   @unique
  name      String
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workouts Workout[]
}

model Workout {
  id               String   @id @default(cuid())
  name             String
  userId           String
  sessionInput     Json
  generatedSession Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
