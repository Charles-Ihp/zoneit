	"info": {
		"title": "GRAVITACIO API",
		"version": "1.0.0",
		"description": "Bouldering workout planner API",
		"contact": {}
	},
	"paths": {
		"/api/workouts": {
			"get": {
				"operationId": "ListWorkouts",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"items": {
										"$ref": "#/components/schemas/WorkoutResponse"
									},
									"type": "array"
								}
							}
						}
					}
				},
				"description": "List all saved workouts for the authenticated user, newest first.",
				"tags": [
					"Workouts"
				],
				"security": [
					{
						"bearerAuth": []
					}
				],
				"parameters": []
			},
			"post": {
				"operationId": "CreateWorkout",
				"responses": {
					"201": {
						"description": "Created",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/WorkoutResponse"
								}
							}
						}
					}
				},
				"description": "Save a new generated workout session.",
				"tags": [
					"Workouts"
				],
				"security": [
					{
						"bearerAuth": []
					}
				],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreateWorkoutBody"
							}
						}
					}
				}
			}
		},
		"/api/workouts/{id}": {
			"get": {
				"operationId": "GetWorkout",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/WorkoutResponse"
								}
							}
						}
					}
				},
				"description": "Get a single saved workout by ID (must belong to the authenticated user).",
				"tags": [
					"Workouts"
				],
				"security": [
					{
						"bearerAuth": []
					}
				],
				"parameters": [
					{
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			},
			"put": {
				"operationId": "UpdateWorkout",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/WorkoutResponse"
								}
							}
						}
